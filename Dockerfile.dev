FROM golang:1.26-alpine

# Install build dependencies for Go and Air
RUN apk add --no-cache git bash build-base

# Install air for live reloading in Go
RUN go install github.com/air-verse/air@latest

WORKDIR /app

# Cache dependencies
COPY go.mod go.sum ./
RUN go mod download

# Copy application source
COPY . .

# Expose API port
EXPOSE 8081

# Start hot-reload development server
CMD ["air", "-c", ".air.docker.toml"]
